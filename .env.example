# ── AWS / DynamoDB ────────────────────────────────────────────────────────────
# Required for the tasks and config API routes, and for the CLI seed scripts.
#
# After running `sst deploy --stage production`, the access key values are
# managed by SST (the old manually-created key can then be deleted from AWS).
# Until then, copy the values from the AWS console.
#
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key   # never commit this value

# ── DynamoDB Table Names ───────────────────────────────────────────────────────
# Injected by SST stack outputs after `sst deploy`. For local development,
# set these to the real table names from your AWS account.
#
# ONBOARDING_TASKS_TABLE=onboarding-tasks
# ONBOARDING_CONFIG_TABLE=onboarding-config
# ONBOARDING_MEETINGS_TABLE=onboarding-meetings
# ONBOARDING_SENTIMENT_TABLE=onboarding-sentiment
# ONBOARDING_ORG_CHART_TABLE=onboarding-org-chart
# ONBOARDING_SLACK_MESSAGES_TABLE=onboarding-slack-messages
# ONBOARDING_MANAGERS_TABLE=onboarding-managers

# ── Cognito / Auth ────────────────────────────────────────────────────────────
# Required for authentication. Values come from SST stack outputs after
# `npx sst deploy --stage prod` then `npx sst output --stage prod`.
#
# NEXTAUTH_SECRET=           # generate: openssl rand -base64 32  (must be ≥32 bytes for JWE)
# NEXTAUTH_URL=              # http://localhost:3000 for local dev; set prod URL in Vercel dashboard
# AUTH_TRUST_HOST=1          # Required on Vercel — trusts X-Forwarded-Host from the edge proxy
# COGNITO_USER_POOL_ID=      # from SST stack output: userPoolId
# COGNITO_CLIENT_ID=         # from SST stack output: userPoolClientId
# COGNITO_REGION=eu-west-1   # Cognito region (same as AWS_REGION)
#
# Note: no COGNITO_CLIENT_SECRET — the App Client uses generateSecret: false (SRP flow)

# ── Phase 2 variables (not yet used) ─────────────────────────────────────────
# DATABASE_URL=postgresql://localhost:5432/onboarding
# REDIS_URL=redis://localhost:6379
# WATSONX_API_KEY=your-watsonx-key   # store in IBM Key Protect, not here
