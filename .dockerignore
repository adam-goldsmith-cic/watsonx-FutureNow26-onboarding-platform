# Dependencies and build artifacts
node_modules
.next
.turbo

# Generated by Next.js at build time — must not be pre-copied (causes EACCES in container)
next-env.d.ts

# Environment files — NEVER bake secrets into the image
.env
.env.local
.env*.local

# Dev/test tooling — not needed in the image
vitest.config.ts
src/test

# Source control and editor
.git
.gitignore
.github
.vscode

# Docs and planning
starter_docs
docs
mvp-plan.md
AGENTS.md
CLAUDE.md
README.md

# OS artefacts
.DS_Store
*.pem
npm-debug.log*
