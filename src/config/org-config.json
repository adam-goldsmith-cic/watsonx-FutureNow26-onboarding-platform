        {
          "id": "ann-1",
          "message": "Welcome to IBM Future Now! Your onboarding journey starts today. Check your checklist for Day 1 tasks.",
          "audience": "all",
          "expiresAt": "2026-12-31T23:59:59.000Z"
        },
        {
          "id": "ann-2",
          "message": "All new starters must complete Security Awareness training by end of Week 1.",
          "audience": "cohort",
          "expiresAt": "2026-12-31T23:59:59.000Z"
        }
      ]
    }
  },
  {
    "pluginId": "checklist",
    "enabled": true,
    "order": 2,
    "config": {
      "title": "First Week Checklist",
      "tasks": [
        {
          "id": "collect-laptop",
          "label": "Collect IBM laptop from IT",
          "category": "IT",
          "dueDayOffset": 1,
          "mandatory": true,
          "roles": ["all"]
        },
        {
          "id": "setup-w3id",
          "label": "Set up IBM w3id account and MFA",
          "category": "IT",
          "dueDayOffset": 1,
          "mandatory": true,
          "roles": ["all"],
          "link": { "label": "w3id setup guide →", "url": "/docs/w3id-setup" }
        },
        {
          "id": "complete-security",
          "label": "Complete Security Awareness training",
          "category": "SEC",
          "dueDayOffset": 5,
          "mandatory": true,
          "roles": ["all"],
          "link": { "label": "Open training →", "url": "/training" }
        },
        {
          "id": "complete-coc",
          "label": "Read and acknowledge IBM Code of Conduct",
          "category": "HR",
          "dueDayOffset": 5,
          "mandatory": true,
          "roles": ["all"]
        },
        {
          "id": "meet-manager",
          "label": "Attend 1:1 with your line manager",
          "category": "MGR",
          "dueDayOffset": 2,
          "mandatory": true,
          "roles": ["all"]
        },
        {
          "id": "meet-team",
          "label": "Join team standup and introduce yourself",
          "category": "TEAM",
          "dueDayOffset": 2,
          "mandatory": false,
          "roles": ["all"]
        },
        {
          "id": "setup-vpn",
          "label": "Install and test IBM VPN",
          "category": "IT",
          "dueDayOffset": 3,
          "mandatory": true,
          "roles": ["all"],
          "link": { "label": "VPN guide →", "url": "/docs/vpn" }
        },
        {
          "id": "setup-slack",
          "label": "Set up IBM Slack and join team channels",
          "category": "IT",
          "dueDayOffset": 3,
          "mandatory": true,
          "roles": ["all"]
        },
        {
          "id": "submit-bank",
          "label": "Submit bank details to HR via Workday",
          "category": "HR",
          "dueDayOffset": 3,
          "mandatory": true,
          "roles": ["all"]
        },
        {
          "id": "complete-gdpr",
          "label": "Complete GDPR & Data Privacy training",
          "category": "SEC",
          "dueDayOffset": 7,
          "mandatory": true,
          "roles": ["all"]
        },
        {
          "id": "setup-github",
          "label": "Request access to IBM GitHub Enterprise",
          "category": "IT",
          "dueDayOffset": 5,
          "mandatory": false,
          "roles": ["all"],
          "link": { "label": "Request access →", "url": "/docs/github-access" }
        },
        {
          "id": "30day-checkin",
          "label": "Book 30-day check-in with your manager",
          "category": "MGR",
          "dueDayOffset": 7,
          "mandatory": true,
          "roles": ["all"]
        }
      ]
    }
