{
  "name": "ibm-onboarding",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "deploy:backend": "(eval $(aws configure export-credentials --profile default --format env) && npx sst deploy --stage production)",
    "deploy:frontend": "npx vercel deploy",
    "dev": "next dev",
    "seed-config": "tsx --env-file=.env.local scripts/seed-config.ts",
    "seed-tasks": "tsx --env-file=.env.local scripts/seed-tasks.ts",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1087.0",
    "@aws-sdk/lib-dynamodb": "^3.1087.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "sst": "4.17.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
